{
  "name": "derive-md",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agentic Markdown artifact manager and Pi launcher.",
  "main": "bin/derive-md.mjs",
  "bin": {
    "derive-md": "bin/derive-md.mjs"
  },
  "keywords": [
    "derive-md",
    "markdown",
    "agents-md",
    "pi"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:pi-mock": "echo 'no pi extension tests'",
    "agents-md:lint": "node bin/derive-md.mjs lint --profile agents-md AGENTS.md",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run agents-md:lint && npm run test:pi-mock"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.3.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0"
  }
}
